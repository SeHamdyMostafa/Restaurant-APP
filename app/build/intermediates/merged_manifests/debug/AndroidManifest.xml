        android:minSdkVersion="22"
        android:targetSdkVersion="32" />

    <application
        android:allowBackup="true"
        android:appComponentFactory="androidx.core.app.CoreComponentFactory"
        android:debuggable="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:testOnly="true"
        android:theme="@style/Theme.Resturant" >
        <activity
            android:name="com.example.resturant.Cart_Model"
            android:exported="false" />
        <activity
            android:name="com.example.resturant.Cart"
            android:exported="false" />
        <activity
            android:name="com.example.resturant.Change_password"
            android:exported="false" />
        <activity
            android:name="com.example.resturant.Setting"
            android:exported="false" />
        <activity
            android:name="com.example.resturant.Food_Model"
            android:exported="false" />
        <activity
            android:name="com.example.resturant.Purchases"
            android:exported="false" />
        <activity
            android:name="com.example.resturant.Pizza_food"
            android:exported="false" />
        <activity
            android:name="com.example.resturant.Mac_food"
            android:exported="false" />
        <activity
            android:name="com.example.resturant.KFC"
            android:exported="false" />
        <activity
            android:name="com.example.resturant.MainActivity"
            android:exported="false" />
        <activity
            android:name="com.example.resturant.Register"
            android:exported="false" />
        <activity
            android:name="com.example.resturant.Login"
            android:exported="false" />
        <activity
            android:name="com.example.resturant.Profile"
            android:exported="false" />
        <activity
            android:name="com.example.resturant.Splash"
            android:exported="true" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="com.example.resturant.androidx-startup"
            android:exported="false" >
            <meta-data
                android:name="androidx.emoji2.text.EmojiCompatInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.lifecycle.ProcessLifecycleInitializer"
                android:value="androidx.startup" />
        </provider>

        <uses-library
            android:name="androidx.window.extensions"
            android:required="false" />
        <uses-library
            android:name="androidx.window.sidecar"
            android:required="false" />
